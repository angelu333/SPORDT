# ============================================================
# SporDT — Variables de Entorno
# ============================================================
# IMPORTANTE: Nunca subas este archivo al repositorio.
# Asegúrate de que .env esté en el .gitignore.
# Para producción, configura estas variables directamente
# en el servidor (variables de entorno del sistema).
# ============================================================

# ── Base de Datos ──
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_NAME=spordt_db
DB_PORT=3306

# ── Servidor ──
PORT=3000

# ── Frontend autorizado (CORS) ──
# En desarrollo: http://localhost:4200
# En producción: https://tu-dominio.com
# Para múltiples orígenes separar con coma: https://app.com,https://admin.app.com
FRONTEND_URL=http://localhost:4200

# ── JWT (JSON Web Token) ──
# CRÍTICO: Cambia este valor por una cadena larga y aleatoria antes de producción.
# Genera uno seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_UNA_CADENA_ALEATORIA_MUY_LARGA_Y_SECRETA
JWT_EXPIRES_IN=8h
